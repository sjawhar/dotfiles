{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/master/assets/oh-my-opencode.schema.json",
  "auto_update": false,
  "claude_code": {
    "mcp": true,
    "commands": false,
    "skills": false,
    "agents": false,
    "hooks": false,
    "plugins": false
  },
  "sisyphus_agent": {
    "default_builder_enabled": true,
    "planner_enabled": true,
    "replace_plan": true
  },
  "agents": {
    "sisyphus": {
      "model": "anthropic/claude-opus-4-7",
      "variant": "max"
    },
    "hephaestus": {
      "model": "openai/gpt-5.4",
      "variant": "high"
    },
    "prometheus": {
      "model": "anthropic/claude-opus-4-7",
      "variant": "max"
    },
    "metis": {
      "model": "openai/gpt-5.4",
      "variant": "high"
    },
    "momus": {
      "model": "openai/gpt-5.4",
      "variant": "xhigh"
    },
    "oracle": {
      "model": "openai/gpt-5.4",
      "variant": "high"
    },
    "atlas": {
      "model": "anthropic/claude-sonnet-4-6"
    },
    "librarian": {
      "model": "anthropic/claude-sonnet-4-6"
    },
    "explore": {
      "model": "anthropic/claude-haiku-4-5"
    },
    "multimodal-looker": {
      "model": "openai/gpt-5.4",
      "variant": "medium"
    },
    "athena": {
      "council": {
        "members": [
          {
            "model": "anthropic/claude-opus-4-7",
            "name": "Claude",
            "variant": "max"
          },
          {
            "model": "openai/gpt-5.4",
            "name": "GPT"
          },
          {
            "model": "google/gemini-3.1-pro-preview",
            "name": "Gemini"
          }
        ]
      }
    }
  },
  "categories": {
    "ultrabrain": {
      "model": "anthropic/claude-opus-4-7",
      "variant": "max"
    },
    "deep": {
      "model": "openai/gpt-5.4",
      "variant": "medium"
    },
    "visual-engineering": {
      "model": "google/gemini-3.1-pro-preview",
      "variant": "high"
    },
    "quick": {
      "model": "anthropic/claude-haiku-4-5"
    },
    "unspecified-low": {
      "model": "anthropic/claude-sonnet-4-6"
    },
    "unspecified-high": {
      "model": "anthropic/claude-opus-4-7",
      "variant": "max"
    },
    "writing": {
      "model": "google/gemini-3-flash-preview"
    },
    "artistry": {
      "model": "google/gemini-3.1-pro-preview",
      "variant": "high"
    }
  },
  "disabled_hooks": [
    "directory-readme-injector",
    "think-mode",
    "preemptive-compaction",
    "rules-injector",
    "ralph-loop",
    "tasks-todowrite-disabler",
    "auto-slash-command"
  ],
  "disabled_commands": [],
  "disabled_mcps": [],
  "disabled_skills": [],
  "disabled_tools": [],
  "hashline_edit": true,
  "runtime_fallback": true,
  "tmux": {
    "enabled": true,
    "layout": "main-vertical",
    "isolation": "session"
  }
}
