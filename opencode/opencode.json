      }
    }
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },
    "ceramic": {
      "type": "remote",
      "url": "https://mcp.ceramic.ai/mcp",
      "enabled": true
    }
  },
  "autoupdate": false,
  "experimental": {
    "disable_paste_summary": true
  }
}
