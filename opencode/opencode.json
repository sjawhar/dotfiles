{
  "$schema": "https://opencode.ai/config.json",
  "keybinds": {
    "input_line_home": "home",
    "input_line_end": "end",
    "messages_first": "ctrl+home",
    "messages_last": "ctrl+end"
  },
  "plugin": [
    "@sjawhar/opencode-legion-envoy@latest",
    "file://{env:HOME}/.dotfiles/opencode/plugins/dotfiles-bridge.ts",
    "file://{env:HOME}/.dotfiles/opencode/plugins/jj-snapshot.ts",
    "file://{env:HOME}/.dotfiles/opencode/plugins/session-env.ts",
    "https://github.com/sjawhar/opencode-anthropic-auth/releases/download/v0.5.1/sjawhar-opencode-anthropic-auth-0.5.1.tgz",
    "opencody-pty@latest",
    "superpowers@git+https://github.com/obra/superpowers.git#v6.1.1"
  ],
  "references": {
    "inspect_ai": {
      "repository": "github.com/UKGovernmentBEIS/inspect_ai",
      "description": "Inspect AI eval framework (official upstream)"
    },
    "inspect_ai_tl": {
      "repository": "github.com/trajectory-labs-pbc/inspect_ai",
      "description": "Inspect AI eval framework (Trajectory Labs fork)"
    },
    "inspect_evals": {
      "repository": "github.com/UKGovernmentBEIS/inspect_evals",
      "description": "Inspect evals (official upstream)"
    },
    "inspect_flow": {
      "repository": "github.com/meridianlabs-ai/inspect_flow",
      "description": "Inspect Flow (official upstream)"
    },
    "inspect_k8s_sandbox": {
      "repository": "github.com/UKGovernmentBEIS/inspect_k8s_sandbox",
      "description": "Inspect Kubernetes sandbox provider (official upstream)"
    },
    "inspect_k8s_sandbox_tl": {
      "repository": "github.com/trajectory-labs-pbc/inspect_k8s_sandbox",
      "description": "Inspect Kubernetes sandbox provider (Trajectory Labs fork)"
    },
    "inspect_scout": {
      "repository": "github.com/meridianlabs-ai/inspect_scout",
      "description": "Inspect Scout (official upstream)"
    },
    "inspect_swe": {
      "repository": "github.com/meridianlabs-ai/inspect_swe",
      "description": "Inspect SWE (official upstream)"
    },
    "inspect_swe_tl": {
      "repository": "github.com/trajectory-labs-pbc/inspect_swe",
      "description": "Inspect SWE (Trajectory Labs fork)"
    },
    "inspect_action": {
      "repository": "github.com/METR/inspect-action",
      "description": "METR inspect-action / hawk (official upstream)"
    }
  },
  "provider": {
    "anthropic": {
      "models": {
        "claude-fable-5": {
          "name": "Claude Fable 5",
          "limit": {
            "context": 1000000,
            "input": 1000000,
            "output": 128000
          },
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf"
            ],
            "output": [
              "text"
            ]
          },
          "variants": {
            "low": {},
            "medium": {},
            "high": {},
            "xhigh": {},
            "max": {}
          }
        }
      }
    },
    "google": {
      "models": {
        "antigravity-gemini-3-pro": {
          "name": "Gemini 3 Pro (Antigravity)",
          "limit": {
            "context": 1048576,
            "output": 65535
          },
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf"
            ],
            "output": [
              "text"
            ]
          },
          "variants": {
            "low": {
              "thinkingLevel": "low"
            },
            "high": {
              "thinkingLevel": "high"
            }
          }
        },
        "antigravity-gemini-3.1-pro": {
          "name": "Gemini 3.1 Pro (Antigravity)",
          "limit": {
            "context": 1048576,
            "output": 65535
          },
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf"
            ],
            "output": [
              "text"
            ]
          },
          "variants": {
            "low": {
              "thinkingLevel": "low"
            },
            "high": {
              "thinkingLevel": "high"
            }
          }
        },
        "antigravity-gemini-3-flash": {
          "name": "Gemini 3 Flash (Antigravity)",
          "limit": {
            "context": 1048576,
            "output": 65536
          },
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf"
            ],
            "output": [
              "text"
            ]
          },
          "variants": {
            "minimal": {
              "thinkingLevel": "minimal"
            },
            "low": {
              "thinkingLevel": "low"
            },
            "medium": {
