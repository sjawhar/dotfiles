#!/usr/bin/env python3
"""Git credential helper that authenticates as a GitHub App.

Generates GitHub App installation tokens on demand and caches them.
Works as a standard git credential helper — git calls this automatically
when credentials are needed for github.com.

Required environment variables:
  GH_APP                — app slug (e.g., "legion-implementer")
  GH_APP_ID             — GitHub App ID
  GH_APP_INSTALLATION_ID — Installation ID for the target org/repo
  GH_APP_PRIVATE_KEY    — PEM private key contents (NOT a file path)

Usage in git config:
  [credential "https://github.com"]
    helper = gh-app

Or via environment:
  GIT_CONFIG_COUNT=1
  GIT_CONFIG_KEY_0=credential.https://github.com.helper
  GIT_CONFIG_VALUE_0=gh-app
"""

import json
import os
import sys
import time
from pathlib import Path

CACHE_DIR = Path.home() / ".cache" / "gh-app-tokens"
TOKEN_REFRESH_MARGIN = 300  # Refresh 5 minutes before expiry


def generate_jwt(app_id: str, private_key: str) -> str:
    """Generate a JWT for GitHub App authentication (RS256, 10-minute expiry)."""
    import jwt

    now = int(time.time())
    payload = {
        "iat": now - 60,  # Issued 60s ago (clock skew tolerance)
        "exp": now + 600,  # Expires in 10 minutes
        "iss": app_id,
    }
    return jwt.encode(payload, private_key, algorithm="RS256")


def get_installation_token(app_id: str, installation_id: str, private_key: str) -> dict:
    """Exchange a JWT for an installation access token via GitHub API."""
    import urllib.request

    token = generate_jwt(app_id, private_key)
    req = urllib.request.Request(
        f"https://api.github.com/app/installations/{installation_id}/access_tokens",
        method="POST",
        headers={
            "Authorization": f"Bearer {token}",
            "Accept": "application/vnd.github+json",
            "X-GitHub-Api-Version": "2022-11-28",
        },
    )
    with urllib.request.urlopen(req) as resp:
        return json.loads(resp.read())


def get_cached_token(app_slug: str) -> str | None:
    """Return a cached token if it exists and hasn't expired."""
    cache_file = CACHE_DIR / f"{app_slug}.json"
    if not cache_file.exists():
        return None
    try:
        data = json.loads(cache_file.read_text())
        # Parse GitHub's ISO 8601 expiry: "2024-01-01T12:00:00Z"
        from datetime import datetime, timezone

        expires_at = datetime.fromisoformat(data["expires_at"].replace("Z", "+00:00"))
        now = datetime.now(timezone.utc)
        if (expires_at - now).total_seconds() > TOKEN_REFRESH_MARGIN:
            return data["token"]
    except (json.JSONDecodeError, KeyError, ValueError):
        pass
    return None


def cache_token(app_slug: str, token_data: dict) -> None:
    """Cache the token response to disk."""
    CACHE_DIR.mkdir(parents=True, exist_ok=True)
    cache_file = CACHE_DIR / f"{app_slug}.json"
    cache_file.write_text(json.dumps(token_data))
    cache_file.chmod(0o600)


def get_token() -> str:
    """Get a valid installation token (cached or fresh)."""
    app_slug = os.environ.get("GH_APP", "")
    app_id = os.environ.get("GH_APP_ID", "")
    installation_id = os.environ.get("GH_APP_INSTALLATION_ID", "")

    # Resolve private key: env var > base64 env var > secrets helper
    private_key = os.environ.get("GH_APP_PRIVATE_KEY", "")
    if not private_key:
        import base64
        b64_key = os.environ.get("GH_AGENT_APP_PRIVATE_KEY_B64", "")
        if not b64_key:
            # Decrypt on demand via secrets helper
            import subprocess
            try:
                b64_key = subprocess.run(
                    ["secrets", "get", "GH_AGENT_APP_PRIVATE_KEY_B64"],
                    capture_output=True, text=True, check=True,
                ).stdout.strip()
            except (subprocess.CalledProcessError, FileNotFoundError):
                pass
        if b64_key:
            private_key = base64.b64decode(b64_key).decode()

    if not all([app_slug, app_id, installation_id, private_key]):
        missing = [
            name
            for name, val in [
                ("GH_APP", app_slug),
                ("GH_APP_ID", app_id),
                ("GH_APP_INSTALLATION_ID", installation_id),
                ("GH_APP_PRIVATE_KEY / GH_APP_PRIVATE_KEY_B64", private_key),
            ]
            if not val
        ]
        print(f"git-credential-gh-app: missing env vars: {', '.join(missing)}", file=sys.stderr)
        sys.exit(1)

    # Try cache first
    cached = get_cached_token(app_slug)
    if cached:
        return cached

    # Generate fresh token
    print(f"git-credential-gh-app: generating token for {app_slug}...", file=sys.stderr)
    token_data = get_installation_token(app_id, installation_id, private_key)
    cache_token(app_slug, token_data)
    return token_data["token"]


def main():
    if len(sys.argv) < 2:
        print("usage: git-credential-gh-app <get|store|erase>", file=sys.stderr)
        sys.exit(1)

    action = sys.argv[1]

    if action != "get":
        # store and erase are no-ops — we manage our own cache
        sys.exit(0)

    # Read the credential request from stdin
    request = {}
    for line in sys.stdin:
        line = line.strip()
        if not line:
            break
        if "=" in line:
            key, _, value = line.partition("=")
            request[key] = value

    # Only handle github.com requests
    host = request.get("host", "")
    if "github.com" not in host:
        sys.exit(0)

    # Only activate if GH_APP is set
    if not os.environ.get("GH_APP"):
        sys.exit(0)

    token = get_token()
    print(f"protocol={request.get('protocol', 'https')}")
    print(f"host={host}")
    print("username=x-access-token")
    print(f"password={token}")


if __name__ == "__main__":
    main()
