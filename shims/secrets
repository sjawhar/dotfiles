#!/bin/bash
# Secrets wrapper — selectively inject secrets from sops-encrypted file(s) into commands.
#
# Reads three files and unions their keys:
#   $DOTFILES_DIR/secrets.env        committed (shared, pushed) — agent tier
#   $DOTFILES_DIR/secrets.local.env  gitignored (local-only), optional; wins on key conflicts
#   $DOTFILES_DIR/secrets.human.env  committed — human tier: encrypted only to the
#                                    YubiKey + recovery key, NOT the machine-resident agent
#                                    key. Decryption requires the YubiKey (touch).
#
# Usage:
#   secrets edit                        Open the committed secrets file in editor
#   secrets edit-local                  Open the local (gitignored) secrets file in editor
#   secrets edit-human                  Open the human-tier secrets file in editor (YubiKey)
#   secrets list                        List secret key names (union of both files)
#   secrets get KEY                     Print value of a single secret
#   secrets KEY1 KEY2 -- command args   Run command with specific secrets in env
set -euo pipefail

DOTFILES_DIR="${DOTFILES_DIR:-${HOME}/.dotfiles}"
SECRETS_FILE="${DOTFILES_DIR}/secrets.env"
SECRETS_LOCAL_FILE="${DOTFILES_DIR}/secrets.local.env"
SECRETS_HUMAN_FILE="${DOTFILES_DIR}/secrets.human.env"

# Decrypt the local overlay first (so its keys win via `head -1`), then the shared file.
# Human tier is separate: only decrypted on demand (requires YubiKey presence + touch).
decrypt_all() {
    if [ -f "$SECRETS_LOCAL_FILE" ]; then
        sops -d --output-type dotenv "$SECRETS_LOCAL_FILE"
    fi
    sops -d --output-type dotenv "$SECRETS_FILE"
}

# Human-tier decrypts require a YubiKey touch. To avoid a touch per invocation,
# cache the decrypted values in RAM (mode 600, /dev/shm - never survives reboot)
# for SECRETS_HUMAN_CACHE_TTL seconds (default 300). One touch opens a window.
HUMAN_CACHE="/dev/shm/.secrets-human-$(id -u)"
HUMAN_CACHE_TTL="${SECRETS_HUMAN_CACHE_TTL:-300}"

decrypt_human() {
    [ -f "$SECRETS_HUMAN_FILE" ] || return 0
    if [ -f "$HUMAN_CACHE" ]; then
        local age
        age=$(( $(date +%s) - $(stat -c %Y "$HUMAN_CACHE") ))
        if [ "$age" -lt "$HUMAN_CACHE_TTL" ]; then
            cat "$HUMAN_CACHE"
            return 0
        fi
        rm -f "$HUMAN_CACHE"
    fi
    local plain
    plain=$(sops -d --output-type dotenv "$SECRETS_HUMAN_FILE") || {
        echo "secrets: failed to decrypt human tier (${SECRETS_HUMAN_FILE##*/}) — YubiKey touch required" >&2
        if [ -n "${OPENCODE_SESSION_ID:-}" ] || [ -n "${CLAUDECODE:-}" ] || ! [ -t 2 ]; then
            cat >&2 <<'AGENTMSG'
AGENT NOTICE: this secret is human-tier and needs a physical YubiKey touch.
Do NOT retry in a loop. Ask the user to either:
  1. touch the YubiKey while you retry the command once, or
  2. run `secrets get <KEY>` in their own terminal (one touch opens a
     no-touch window for several minutes; your retry will then succeed).
AGENTMSG
        fi
        return 1
    }
    (umask 077; printf '%s\n' "$plain" > "$HUMAN_CACHE")
    printf '%s\n' "$plain"
}

case "${1:-}" in
    edit)       exec sops "$SECRETS_FILE" ;;
    edit-local) exec sops "$SECRETS_LOCAL_FILE" ;;
    edit-human) exec sops "$SECRETS_HUMAN_FILE" ;;
    list)
        decrypt_all | cut -d= -f1 | awk 'NF && !seen[$0]++'
        if [ -f "$SECRETS_HUMAN_FILE" ]; then
            # Names only; tolerate unreachable YubiKey but say so loudly.
            decrypt_human 2>/dev/null | cut -d= -f1 | awk 'NF' | sed 's/$/  (human tier)/' \
                || echo "secrets: human tier unavailable (YubiKey not reachable)" >&2
        fi
        exit ;;
    get)
        key="${2:?usage: secrets get KEY}"
        val=$(decrypt_all | grep "^${key}=" | head -1 | cut -d= -f2- || true)
        if [ -z "$val" ] && [ -f "$SECRETS_HUMAN_FILE" ]; then
            human_secrets=$(decrypt_human) || exit 1
            val=$(echo "$human_secrets" | grep "^${key}=" | head -1 | cut -d= -f2- || true)
        fi
        [ -n "$val" ] && { printf '%s\n' "$val"; exit 0; }
        echo "secrets: secret '${key}' not found" >&2; exit 1 ;;
esac

# Collect key names until --
keys=()
while [ $# -gt 0 ] && [ "$1" != "--" ]; do
    keys+=("$1")
    shift
done
[ "${1:-}" = "--" ] && shift

if [ ${#keys[@]} -eq 0 ] || [ $# -eq 0 ]; then
    echo "Usage: secrets KEY1 [KEY2 ...] -- command [args...]" >&2
    exit 1
fi

# Decrypt agent tier once; pull human tier only if a requested key needs it.
all_secrets=$(decrypt_all)
human_secrets=""
human_loaded=false

env_args=()
for key in "${keys[@]}"; do
    val=$(echo "$all_secrets" | grep "^${key}=" | head -1 | cut -d= -f2- || true)
    if [ -z "$val" ] && [ -f "$SECRETS_HUMAN_FILE" ]; then
        if ! $human_loaded; then
            human_secrets=$(decrypt_human) || exit 1
            human_loaded=true
        fi
        val=$(echo "$human_secrets" | grep "^${key}=" | head -1 | cut -d= -f2- || true)
    fi
    if [ -z "$val" ]; then
        echo "secrets: secret '${key}' not found" >&2
        exit 1
    fi
    env_args+=("${key}=${val}")
done

exec env "${env_args[@]}" "$@"
