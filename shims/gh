#!/bin/bash
# gh wrapper for jj (Jujutsu) compatibility
#
# Problem: gh CLI uses `git symbolic-ref HEAD` to detect current branch.
# jj operates in detached HEAD mode, so this detection fails.
#
# Solution: Two-layer fix for pr subcommands in jj repos:
#   1. Git wrapper: intercepts `git symbolic-ref HEAD` (and similar) to
#      return the jj bookmark name, preventing gh's "could not determine
#      current branch" error.
#   2. Arg injection: for commands that need branch context, inject the
#      bookmark as --head flag or positional argument.
#
# Commands with arg injection:
#   gh pr create           -> adds --head <bookmark>
#   gh pr view             -> adds <bookmark> positional arg
#   gh pr checks           -> adds <bookmark> positional arg
#   gh pr diff             -> adds <bookmark> positional arg
#   gh pr merge            -> adds <bookmark> positional arg
#   gh pr checkout         -> adds <bookmark> positional arg
#   gh pr edit             -> adds <bookmark> positional arg
#   gh pr comment          -> adds <bookmark> positional arg
#   gh pr ready            -> adds <bookmark> positional arg
#   gh pr review           -> adds <bookmark> positional arg
#   gh pr update-branch    -> adds <bookmark> positional arg
#
# Commands NOT handled (require explicit target, no default):
#   gh pr close, lock, unlock, reopen, revert
#
# Commands that don't need branch context:
#   gh pr list, gh pr status, all non-pr commands

set -euo pipefail

# --- GitHub App identity (route-driven) ---
# Resolve the repo a gh command will act on -- mirroring gh's own base-repo
# resolution -- then look up the credential helper that matches it. If that
# helper is `!gh-app-token <profile>`, mint an installation token and export
# GH_TOKEN so gh authenticates as that profile. When nothing matches (e.g. a
# fork whose base repo is an unrouted upstream), GH_TOKEN is left unset and gh
# falls back to the user's own auth. In interactive shells (no agent include
# loaded) only the default user-helper matches, so no token is exported.

# Normalize a remote URL to https form with a trailing .git.
_gh_normalize_url() {
    local url="$1"
    if [[ -z "$url" ]]; then return 0; fi
    # SSH form git@host:owner/repo[.git] -> https://host/owner/repo[.git]
    if [[ "$url" =~ ^git@([^:]+):(.+)$ ]]; then
        url="https://${BASH_REMATCH[1]}/${BASH_REMATCH[2]}"
    fi
    # Strip ssh:// prefix if present.
    url="${url/#ssh:\/\/git@/https://}"
    # Ensure trailing .git for stable matching (matches git's credential URL).
    [[ "$url" == *.git ]] || url="${url}.git"
    printf '%s\n' "$url"
}

# Build an https URL from a gh repo spec: a URL, host/owner/repo, or owner/repo.
_gh_url_from_spec() {
    local spec="$1"
    if [[ -z "$spec" ]]; then return 0; fi
    if [[ "$spec" == *://* ]]; then
        _gh_normalize_url "$spec"
        return 0
    fi
    local slashes="${spec//[^\/]/}"
    if [[ "${#slashes}" -ge 2 ]]; then
        _gh_normalize_url "https://${spec}"
    else
        _gh_normalize_url "https://github.com/${spec}"
    fi
}

# Resolve the repo a gh invocation targets, matching gh's base-repo resolution:
#   1. explicit -R/--repo argument
#   2. `gh repo set-default` (remote.<name>.gh-resolved in git config)
#   3. remote preference order: upstream, github, origin, then any other remote
# Emits a normalized https URL, or nothing if it can't be determined.
# Extract the target owner from `gh api` arguments: REST paths like
# repos/{owner}/{repo}/..., orgs/{owner}/..., users/{owner}/..., or GraphQL
# query bodies containing repository(owner:"X") / organization(login:"X").
# Emits the owner, or nothing when the invocation carries no owner signal
# (then remote-based resolution applies). Pure node-ID GraphQL mutations
# (e.g. addProjectV2ItemById) have no owner signal; prefix those with
# GH_APP_OWNER=<owner>, which gh-app-token honors ahead of the path.
_gh_owner_from_api_args() {
    local -a args=("$@")
    local a owner
    for a in "${args[@]:1}"; do
        case "$a" in
            -*) continue ;;
        esac
        case "$a" in
            repos/*|/repos/*|orgs/*|/orgs/*|users/*|/users/*)
                owner="${a#/}"
                owner="${owner#repos/}"; owner="${owner#orgs/}"; owner="${owner#users/}"
                owner="${owner%%/*}"
                # Strip query strings on bare segments like orgs/foo?page=2
                owner="${owner%%\?*}"
                # gh expands {owner}/{repo} placeholders from the current repo;
                # emit nothing so remote-based resolution handles those.
                if [[ -n "$owner" && "$owner" != *"{"* ]]; then printf '%s\n' "$owner"; fi
                return 0
                ;;
        esac
    done
    # GraphQL: scan flag values for the first repository(owner:...) or
    # organization(login:...) target. Whitespace-tolerant, single or double
    # quotes. First match wins.
    local joined
    joined="${args[*]}"
    if [[ "$joined" =~ (repository[[:space:]]*\([[:space:]]*owner[[:space:]]*:[[:space:]]*[\"\']([A-Za-z0-9._-]+)[\"\'])|(organization[[:space:]]*\([[:space:]]*login[[:space:]]*:[[:space:]]*[\"\']([A-Za-z0-9._-]+)[\"\']) ]]; then
        owner="${BASH_REMATCH[2]:-${BASH_REMATCH[4]}}"
        if [[ -n "$owner" ]]; then printf '%s\n' "$owner"; return 0; fi
    fi
    return 0
}

_gh_resolve_target_url() {
    local -a args=("$@")
    local argc=$# i=0 a
    # 0. gh api: derive the owner from the REST path or GraphQL query body.
    #    These invocations carry no -R and often run outside the target repo's
    #    checkout, so remote-based resolution would route to the wrong owner.
    if [[ "${args[0]:-}" == "api" ]]; then
        local api_owner
        api_owner=$(_gh_owner_from_api_args "$@")
        if [[ -n "$api_owner" ]]; then
            # Only the first path segment (the owner) matters for credential
            # routing; "gh-api" is a placeholder repo segment.
            _gh_url_from_spec "${api_owner}/gh-api"
            return 0
        fi
    fi
    # 1. explicit -R / --repo
    while [[ $i -lt $argc ]]; do
        a="${args[$i]}"
        case "$a" in
            -R|--repo)
                if [[ $((i + 1)) -lt $argc ]]; then
                    _gh_url_from_spec "${args[$((i + 1))]}"
                    return 0
                fi
                ;;
            --repo=*) _gh_url_from_spec "${a#--repo=}"; return 0 ;;
            -R=*)     _gh_url_from_spec "${a#-R=}"; return 0 ;;
        esac
        i=$((i + 1))
    done
    # 2. gh repo set-default (remote.<name>.gh-resolved)
    local line name value
    line=$(git config --get-regexp '^remote\..*\.gh-resolved$' 2>/dev/null | head -n1 || true)
    if [[ -n "$line" ]]; then
        value="${line##* }"
        name="${line#remote.}"
        name="${name%.gh-resolved *}"
        if [[ "$value" == "base" ]]; then
            _gh_normalize_url "$(git remote get-url "$name" 2>/dev/null || true)"
        else
            _gh_url_from_spec "$value"
        fi
        return 0
    fi
    # 3. remote preference order, then any remaining remote
    local r url
    for r in upstream github origin; do
        url=$(git remote get-url "$r" 2>/dev/null || true)
        if [[ -n "$url" ]]; then
            _gh_normalize_url "$url"
            return 0
        fi
    done
    r=$(git remote 2>/dev/null | head -n1 || true)
    if [[ -n "$r" ]]; then
        _gh_normalize_url "$(git remote get-url "$r" 2>/dev/null || true)"
    fi
    return 0
}

if [[ -z "${GH_TOKEN:-}" ]]; then
    _gh_target_url=$(_gh_resolve_target_url "$@")
    if [[ -n "$_gh_target_url" ]]; then
        # Git reports only the final helper for --get-urlmatch, and the dynamic
        # route is a chain ending in the user fallback -- so pick the app
        # helper out of the chain directly.
        _gh_helper=$(git config --get-all 'credential.https://github.com/.helper' 2>/dev/null \
            | grep -m1 '^!gh-app-token ' || true)
        if [[ "$_gh_helper" == "!gh-app-token "* ]]; then
            _gh_profile="${_gh_helper#!gh-app-token }"
            # Build path for the credential request from the URL.
            _gh_path="${_gh_target_url#https://*/}"
            _gh_token=$(printf 'protocol=https\nhost=github.com\npath=%s\n\n' "$_gh_path" \
                        | gh-app-token "$_gh_profile" get 2>/dev/null \
                        | sed -n 's/^password=//p') || true
            if [[ -n "$_gh_token" ]]; then
                export GH_TOKEN="$_gh_token"
            fi
            unset _gh_profile _gh_path _gh_token
        fi
        unset _gh_helper
    fi
    unset _gh_target_url
fi

# Find the real gh binary (skip this specific shim directory)
real_gh() {
    local IFS=':'
    local dotfiles_shims="${DOTFILES_DIR:-$HOME/.dotfiles}/shims"
    for dir in $PATH; do
        [[ "$dir" == "$dotfiles_shims" ]] && continue
        [[ -x "$dir/gh" ]] && { echo "$dir/gh"; return; }
    done
    echo "gh"  # fallback
}

GH="$(real_gh)"

# Check if we're in a jj repo
in_jj_repo() {
    jj root &>/dev/null
}

# Get first bookmark at current change (@ revision)
get_current_bookmark() {
    local bookmarks
    bookmarks=$(jj log -r @ --no-graph -T 'self.bookmarks()' 2>/dev/null) || return 1
    # bookmarks are space-separated; return first one (empty if none)
    local first="${bookmarks%% *}"
    # Validate bookmark name: must be non-empty and contain only safe chars
    # Valid bookmark names: alphanumeric, dash, underscore, dot, slash
    if [[ -n "$first" && "$first" =~ ^[a-zA-Z0-9._/-]+$ ]]; then
        echo "$first"
    else
        return 1
    fi
}

# Error and exit when no bookmark found
die_no_bookmark() {
    echo "Error: No jj bookmark at current change (@)" >&2
    echo "" >&2
    echo "Create one with:" >&2
    echo "  jj bookmark create <name>" >&2
    echo "" >&2
    echo "Or push and create in one step:" >&2
    echo "  jj git push --named=<name>=@" >&2
    exit 1
}

# Run gh with a git wrapper that makes symbolic-ref HEAD return the bookmark.
# This prevents gh's "could not determine current branch" error in jj repos.
# If bookmark is empty, uses a placeholder so gh can proceed.
exec_with_jj_git() {
    local bookmark="${1:-__jj_detached__}"
    shift

    local wrapper_dir
    wrapper_dir=$(mktemp -d)

    cat > "$wrapper_dir/git" << 'GITEOF'
#!/bin/bash
case "$1" in
    symbolic-ref)
        # Only intercept reads (HEAD is last arg), not writes (HEAD followed by ref)
        if [[ "${!#}" == "HEAD" ]]; then
            if [[ " $* " == *" --short "* ]]; then
                printf '%s\n' "$_JJ_BOOKMARK"
            else
                printf 'refs/heads/%s\n' "$_JJ_BOOKMARK"
            fi
            exit 0
        fi
        ;;
    rev-parse)
        if [[ "${!#}" == "HEAD" && " $* " == *" --abbrev-ref "* ]]; then
            printf '%s\n' "$_JJ_BOOKMARK"
            exit 0
        fi
        ;;
    branch)
        if [[ " $* " == *" --show-current "* ]]; then
            printf '%s\n' "$_JJ_BOOKMARK"
            exit 0
        fi
        ;;
esac
# Pass through to real git
IFS=':' read -ra _path_dirs <<< "$PATH"
for _d in "${_path_dirs[@]}"; do
    [[ "$_d" == "$_JJ_WRAPPER_DIR" ]] && continue
    [[ -x "$_d/git" ]] && exec "$_d/git" "$@"
done
echo "error: git not found" >&2
exit 127
GITEOF
    chmod +x "$wrapper_dir/git"

    local rc=0
    _JJ_BOOKMARK="$bookmark" _JJ_WRAPPER_DIR="$wrapper_dir" \
        PATH="$wrapper_dir:$PATH" "$GH" "$@" || rc=$?
    rm -rf "$wrapper_dir" 2>/dev/null || true
    exit "$rc"
}

# Parse arguments to find pr subcommand
# Sets: PR_SUBCOMMAND, PR_SUBCOMMAND_INDEX
parse_pr_subcommand() {
    PR_SUBCOMMAND=""
    PR_SUBCOMMAND_INDEX=-1

    local found_pr=false
    local i=0
    for arg in "$@"; do
        if [[ "$found_pr" == true ]]; then
            # Skip flags between "pr" and subcommand
            if [[ "$arg" == -* ]]; then
                ((i++)) || true
                continue
            fi
            PR_SUBCOMMAND="$arg"
            PR_SUBCOMMAND_INDEX=$i
            return 0
        fi
        [[ "$arg" == "pr" ]] && found_pr=true
        ((i++)) || true
    done
    return 1
}

# Check if --head flag is present
has_head_flag() {
    for arg in "$@"; do
        case "$arg" in
            --head|--head=*) return 0 ;;
        esac
    done
    return 1
}

# Check if positional target is provided after subcommand
# A target is the first non-flag argument after the subcommand
has_positional_target() {
    local subcommand="$1"
    shift

    local found_subcommand=false
    local prev_was_flag_with_value=false

    for arg in "$@"; do
        # Skip flag values (e.g., --repo value)
        if [[ "$prev_was_flag_with_value" == true ]]; then
            prev_was_flag_with_value=false
            continue
        fi

        if [[ "$found_subcommand" == true ]]; then
            # Check if this is a flag
            if [[ "$arg" == -* ]]; then
                # Handle --flag=value syntax (no separate value arg)
                [[ "$arg" == *=* ]] && continue

                # Flags that take a separate value argument
                case "$arg" in
                    -R|--repo|-q|--jq|-t|--template|--json|\
                    -b|--body|-F|--body-file|--branch|\
                    -c|--comment|-r|--reason|--color|-i|--interval|\
                    --subject|--match-head-commit|--author-email|-A|\
                    -l|--label|-m|--milestone|-p|--project|\
                    --reviewer|--assignee|-T|--title|--recover)
                        prev_was_flag_with_value=true
                        ;;
                esac
                continue
            fi
            # Found a non-flag argument = positional target
            return 0
        fi

        [[ "$arg" == "$subcommand" ]] && found_subcommand=true
    done

    return 1
}

# Build new argument array with bookmark inserted after subcommand
# Uses a nameref to avoid subshell issues with arrays
build_args_with_bookmark() {
    local -n result_array=$1
    local subcommand="$2"
    local bookmark="$3"
    shift 3

    local inserted=false

    for arg in "$@"; do
        result_array+=("$arg")
        if [[ "$inserted" == false && "$arg" == "$subcommand" ]]; then
            result_array+=("$bookmark")
            inserted=true
        fi
    done
}

# Main logic
main() {
    # Pass through if not in jj repo
    if ! in_jj_repo; then
        exec "$GH" "$@"
    fi

    # Pass through if not a pr command
    if ! parse_pr_subcommand "$@"; then
        exec "$GH" "$@"
    fi

    # Get bookmark for jj-git compatibility (empty string if none)
    local bookmark
    bookmark=$(get_current_bookmark 2>/dev/null) || bookmark=""

    case "$PR_SUBCOMMAND" in
        # Command using --head flag
        create)
            if has_head_flag "$@"; then
                exec_with_jj_git "$bookmark" "$@"
            fi
            [[ -z "$bookmark" ]] && die_no_bookmark
            exec_with_jj_git "$bookmark" "$@" --head "$bookmark"
            ;;

        # Commands with optional positional target (default to current branch)
        view|checks|diff|merge|checkout|edit|comment|ready|review|update-branch)
            if has_positional_target "$PR_SUBCOMMAND" "$@"; then
                # Even with an explicit target (e.g., PR number), gh still
                # checks current branch internally — use git wrapper
                exec_with_jj_git "$bookmark" "$@"
            fi
            [[ -z "$bookmark" ]] && die_no_bookmark
            # Build new args array with bookmark inserted after subcommand
            local -a new_args=()
            build_args_with_bookmark new_args "$PR_SUBCOMMAND" "$bookmark" "$@"
            exec_with_jj_git "$bookmark" "${new_args[@]}"
            ;;

        # Commands that require explicit target (no injection needed)
        # close, lock, unlock, reopen, revert
        # Also: list, status (don't take branch target)
        *)
            exec_with_jj_git "$bookmark" "$@"
            ;;
    esac
}

# Allow tests to source this file for the resolution helpers without running gh.
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    main "$@"
fi
