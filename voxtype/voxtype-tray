#!/usr/bin/env python3
"""Tray indicator for voxtype recording state.

Monitors the voxtype daemon state file and provides:
- Visual state indication (idle/recording/transcribing)
- Stuck transcription detection (warns after 45s, auto-resets option)
- Force reset for recovering from hung states
"""

import gi
import os
import subprocess
import signal
import time

gi.require_version("Gtk", "3.0")
gi.require_version("AyatanaAppIndicator3", "0.1")
from gi.repository import AyatanaAppIndicator3, Gtk, GLib

DOTFILES_DIR = os.environ.get("DOTFILES_DIR", os.path.expanduser("~/.dotfiles"))
RUNTIME_DIR = os.environ.get("XDG_RUNTIME_DIR", f"/run/user/{os.getuid()}")

STATE_FILE = os.path.join(RUNTIME_DIR, "voxtype", "state")
PID_FILE = os.path.join(RUNTIME_DIR, "voxtype", "pw-record.pid")
WAV_FILE = os.path.join(RUNTIME_DIR, "voxtype", "pw-record.wav")

# Seconds before warning that transcription is stuck
TRANSCRIBE_TIMEOUT_SECS = 45

ICONS = {
    "idle": "audio-input-microphone-symbolic",
    "recording": "media-record-symbolic",
    "transcribing": "emblem-synchronizing-symbolic",
    "error": "dialog-warning-symbolic",
}

LABELS = {
    "idle": "",
    "recording": "REC",
    "transcribing": "...",
    "error": "ERR",
}


class VoxtypeTray:
    def __init__(self):
        self.indicator = AyatanaAppIndicator3.Indicator.new(
            "voxtype-tray",
            ICONS["idle"],
            AyatanaAppIndicator3.IndicatorCategory.APPLICATION_STATUS,
        )
        self.indicator.set_status(AyatanaAppIndicator3.IndicatorStatus.ACTIVE)
        self.indicator.set_label("", "")

        self.last_state = None
        self.transcribing_since = None
        self.stuck_notified = False

        menu = Gtk.Menu()
        item_toggle = Gtk.MenuItem(label="Toggle Recording")
        item_toggle.connect("activate", self._toggle)
        menu.append(item_toggle)
        item_cancel = Gtk.MenuItem(label="Cancel Recording")
        item_cancel.connect("activate", self._cancel)
        menu.append(item_cancel)
        menu.append(Gtk.SeparatorMenuItem())
        item_retranscribe = Gtk.MenuItem(label="Retranscribe Last Recording")
        item_retranscribe.connect("activate", self._retranscribe_last)
        menu.append(item_retranscribe)
        item_paste_last = Gtk.MenuItem(label="Paste Last Transcription")
        item_paste_last.connect("activate", self._paste_last)
        menu.append(item_paste_last)
        menu.append(Gtk.SeparatorMenuItem())
        item_force_reset = Gtk.MenuItem(label="Force Reset")
        item_force_reset.connect("activate", self._force_reset)
        menu.append(item_force_reset)
        item_restart = Gtk.MenuItem(label="Restart Service")
        item_restart.connect("activate", self._restart_service)
        menu.append(item_restart)
        menu.append(Gtk.SeparatorMenuItem())
        item_quit = Gtk.MenuItem(label="Quit Indicator")
        item_quit.connect("activate", lambda _: Gtk.main_quit())
        menu.append(item_quit)
        menu.show_all()
        self.indicator.set_menu(menu)

        GLib.timeout_add(250, self._poll_state)

    def _poll_state(self):
        try:
            with open(STATE_FILE) as f:
                state = f.read().strip()
        except FileNotFoundError:
            state = "idle"

        # Track how long we've been in "transcribing" state
        if state == "transcribing":
            if self.transcribing_since is None:
                self.transcribing_since = time.monotonic()
                self.stuck_notified = False
            elif not self.stuck_notified:
                elapsed = time.monotonic() - self.transcribing_since
                if elapsed > TRANSCRIBE_TIMEOUT_SECS:
                    self._warn_stuck_transcription(elapsed)
        else:
            self.transcribing_since = None
            self.stuck_notified = False

        # Determine display state (show error icon if stuck)
        if self.stuck_notified:
            display_state = "error"
        else:
            display_state = state

        if display_state != self.last_state:
            self.last_state = display_state
            self.indicator.set_icon_full(
                ICONS.get(display_state, ICONS["idle"]), display_state
            )
            self.indicator.set_label(LABELS.get(display_state, ""), "")

        return True

    def _warn_stuck_transcription(self, elapsed):
        """Send notification when transcription appears stuck."""
        self.stuck_notified = True
        secs = int(elapsed)
        subprocess.Popen([
            "notify-send", "--app-name=Voxtype",
            "--urgency=critical", "--expire-time=0",
            "Transcription Stuck",
            f"State has been 'transcribing' for {secs}s.\n"
            "The Deepgram stream may have hung.\n"
            "Use tray menu > Force Reset to recover.",
        ])

    def _force_reset(self, _):
        """Kill orphan pw-record processes, restart the service, clean up state."""
        # Kill any orphaned pw-record processes writing to our recordings dir
        try:
            result = subprocess.run(
                ["pgrep", "-f", "pw-record.*voxtype/recordings"],
                capture_output=True, text=True,
            )
            for pid in result.stdout.strip().split("\n"):
                if pid:
                    try:
                        os.kill(int(pid), signal.SIGTERM)
                    except (ProcessLookupError, ValueError):
                        pass
        except FileNotFoundError:
            pass

        # Clean up runtime files
        for f in [PID_FILE, WAV_FILE]:
            try:
                os.remove(f)
            except FileNotFoundError:
                pass

        # Restart the service
        os.system("systemctl --user restart voxtype.service")

        self.transcribing_since = None
        self.stuck_notified = False

        subprocess.Popen([
            "notify-send", "--app-name=Voxtype", "--expire-time=5000",
            "Voxtype Reset",
            "Service restarted and orphan processes cleaned up.",
        ])

    def _toggle(self, _):
        subprocess.Popen([os.path.join(DOTFILES_DIR, "voxtype/voxtype-record"), "toggle"])

    def _cancel(self, _):
        subprocess.Popen([os.path.join(DOTFILES_DIR, "voxtype/voxtype-record"), "cancel"])

    def _retranscribe_last(self, _):
        subprocess.Popen([os.path.join(DOTFILES_DIR, "voxtype/voxtype-retranscribe-last")])

    def _paste_last(self, _):
        subprocess.Popen([os.path.join(DOTFILES_DIR, "voxtype/voxtype-history-paste-last")])

    def _restart_service(self, _):
        os.system("systemctl --user restart voxtype.service")


if __name__ == "__main__":
    signal.signal(signal.SIGINT, signal.SIG_DFL)
    VoxtypeTray()
    Gtk.main()
