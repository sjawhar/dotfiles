#!/bin/bash
# Restore monitor layout for docked configuration:
#
#   [  LG 4K portrait  ] [     LG Ultrawide      ]
#                       [ Xebec  ] [  Laptop*  ]
#
# Identifies monitors by EDID model name so connector names (DP-6, DP-10, etc.)
# can change across reboots without breaking the layout.

set -euo pipefail

# Parse cosmic-randr list to find connector name for a given model substring
find_connector() {
    local model="$1"
    cosmic-randr list 2>/dev/null | sed 's/\x1b\[[0-9;]*m//g' | awk -v model="$model" '
        /^[A-Za-z]/ { connector = $1 }
        /Model:/ && index($0, model) { print connector; exit }
    '
}

LG4K=$(find_connector "LG HDR 4K")
ULTRAWIDE=$(find_connector "LG ULTRAWIDE")
XEBEC=$(find_connector "Xebec Snap 13")
LAPTOP="eDP-1"

errors=0
if [[ -z "$LG4K" ]]; then
    echo "Warning: LG HDR 4K not found, skipping"
    errors=1
fi
if [[ -z "$ULTRAWIDE" ]]; then
    echo "Warning: LG ULTRAWIDE not found, skipping"
    errors=1
fi
if [[ -z "$XEBEC" ]]; then
    echo "Warning: Xebec Snap 13 not found, skipping"
    errors=1
fi

# LG 4K — portrait (rotate270), far left
if [[ -n "$LG4K" ]]; then
    cosmic-randr mode "$LG4K" 3840 2160 \
        --refresh 59.997 \
        --pos-x 0 --pos-y 0 \
        --transform rotate270 \
        --scale 1
    echo "Configured $LG4K (LG HDR 4K) — left portrait at 0,0"
fi

# LG Ultrawide — right of the 4K portrait (2160px wide), vertically centered
if [[ -n "$ULTRAWIDE" ]]; then
    cosmic-randr mode "$ULTRAWIDE" 3440 1440 \
        --refresh 99.997 \
        --pos-x 2160 --pos-y 1081 \
        --transform normal \
        --scale 1
    echo "Configured $ULTRAWIDE (LG ULTRAWIDE) — center at 2160,1081"
fi

# Xebec — below the ultrawide
if [[ -n "$XEBEC" ]]; then
    cosmic-randr mode "$XEBEC" 1920 1080 \
        --refresh 60.000 \
        --pos-x 2160 --pos-y 2521 \
        --transform normal \
        --scale 1
    echo "Configured $XEBEC (Xebec Snap 13) — below ultrawide at 2160,2521"
fi

# Laptop — right of the Xebec, bottom-aligned
cosmic-randr mode "$LAPTOP" 1920 1200 \
    --refresh 60.003 \
    --pos-x 4080 --pos-y 2521 \
    --transform normal \
    --scale 1
cosmic-randr xwayland --primary "$LAPTOP"
echo "Configured $LAPTOP (laptop) — right of Xebec at 4080,2521 (primary)"

if [[ $errors -eq 0 ]]; then
    echo "All monitors configured successfully"
else
    echo "Layout applied with warnings (see above)"
fi
