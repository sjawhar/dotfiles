#!/bin/bash
# Restore monitor layout for docked configuration:
#   eDP-1 (laptop)             — left (primary)
#   AOC U34G2G4R3 (ultrawide)  — center
#   ASUS VG248 (1080p)         — right

set -euo pipefail

# Parse cosmic-randr list to find connector name for a given model substring
find_connector() {
    local model="$1"
    cosmic-randr list 2>/dev/null | sed 's/\x1b\[[0-9;]*m//g' | awk -v model="$model" '
        /^[A-Za-z]/ { connector = $1 }
        /Model:/ && index($0, model) { print connector; exit }
    '
}

AOC=$(find_connector "U34G2G4R3")
ASUS=$(find_connector "VG248")
LAPTOP="eDP-1"

if [[ -z "$AOC" ]]; then
    echo "Warning: AOC U34G2G4R3 not found, skipping"
fi
if [[ -z "$ASUS" ]]; then
    echo "Warning: ASUS VG248 not found, skipping"
fi

# Apply layout (bottom-aligned, AOC is tallest at 1440px)
# Laptop 1920x1200 on the left (primary)
cosmic-randr mode "$LAPTOP" 1920 1200 \
    --refresh 60.000 \
    --pos-x 0 --pos-y 133 \
    --transform normal \
    --scale 1
cosmic-randr xwayland --primary "$LAPTOP"
echo "Configured $LAPTOP (laptop) — left (primary) at 0,133"

# AOC ultrawide center
if [[ -n "$AOC" ]]; then
    cosmic-randr mode "$AOC" 3440 1440 \
        --refresh 59.973 \
        --pos-x 1920 --pos-y 0 \
        --transform normal \
        --scale 1
    echo "Configured $AOC (AOC U34G2G4R3) — center at 1920,0"
fi

# ASUS 1080p right
if [[ -n "$ASUS" ]]; then
    cosmic-randr mode "$ASUS" 1920 1080 \
        --refresh 60.000 \
        --pos-x 5360 --pos-y 204 \
        --transform normal \
        --scale 1
    echo "Configured $ASUS (ASUS VG248) — right at 5360,204"
fi
