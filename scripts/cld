#!/usr/bin/env bash
# Claude Code launcher.
#
# Loads gh-app-routes.gitconfig for the agent session so git push and gh CLI
# authenticate as the right per-repo identity (legion-personal installation
# for sjawhar/*, legion-work for trajectory-labs-pbc/*, your gh user auth
# elsewhere). Mirrors the env setup in scripts/oc. Private key is fetched
# lazily by the gh-app-token helper via `secrets get`.
set -euo pipefail

# --- gh-app routing config (per-repo credential routing for git+gh) ---
# Agents authenticate via per-repo routing (sjawhar/* uses legion-personal
# installation, trajectory-labs-pbc/* uses legion-work, others fall through
# to your gh user auth). Only loaded by agent shells; interactive shells
# are unaffected. See gh-app-routes.gitconfig and shims/gh-app-token.
GIT_CONFIG_COUNT=$((${GIT_CONFIG_COUNT:-0} + 1))
_idx=$((GIT_CONFIG_COUNT - 1))
export GIT_CONFIG_COUNT
export "GIT_CONFIG_KEY_${_idx}"=include.path
export "GIT_CONFIG_VALUE_${_idx}"="${DOTFILES_DIR:-$HOME/.dotfiles}/gh-app-routes.gitconfig"
unset _idx

exec claude --dangerously-skip-permissions "$@"
