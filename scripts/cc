#!/usr/bin/env bash
# Claude Code launcher.
#
# Sets up GitHub App identity so agent sessions push/create PRs as
# legion-implementer[bot] instead of the user's personal account. Mirrors
# the env setup in scripts/oc. Private key is fetched lazily by the
# git-credential-gh-app helper via `secrets get`.
set -euo pipefail

# --- GitHub App identity for agent sessions ---
export GH_APP=legion-implementer
export GH_APP_ID=3202636
export GH_APP_INSTALLATION_ID=119469290

# Configure git to use the GitHub App credential helper for github.com
export GIT_CONFIG_COUNT=${GIT_CONFIG_COUNT:-0}
GIT_CONFIG_COUNT=$((GIT_CONFIG_COUNT + 2))
export GIT_CONFIG_KEY_$((GIT_CONFIG_COUNT - 2))=credential.https://github.com.helper
export GIT_CONFIG_VALUE_$((GIT_CONFIG_COUNT - 2))=gh-app
export GIT_CONFIG_KEY_$((GIT_CONFIG_COUNT - 1))=credential.https://github.com.useHttpPath
export GIT_CONFIG_VALUE_$((GIT_CONFIG_COUNT - 1))=true

exec claude --dangerously-skip-permissions "$@"
