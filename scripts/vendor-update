#!/bin/bash
set -euo pipefail
VENDOR_DIR="${HOME}/.dotfiles/vendor"

for dir in "$VENDOR_DIR"/*/; do
    [ -d "$dir/.jj" ] || continue
    name=$(basename "$dir")
    echo "Updating $name..."
    ( cd "$dir" && jj git fetch && jj rebase -d main@origin 2>/dev/null ||
        jj rebase -d master@origin 2>/dev/null ||
        echo "  Warning: couldn't rebase $name (check default branch)" )
done
