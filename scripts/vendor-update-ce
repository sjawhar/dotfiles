#!/bin/bash
# Regenerate compound-engineering OpenCode artifacts after vendor update
set -euo pipefail

source "${HOME}/.dotfiles/installers/lib.sh"

CE_DIR="${HOME}/.dotfiles/vendor/compound-engineering"
CE_PLUGIN="${CE_DIR}/plugins/compound-engineering"
OPENCODE_DIR="${HOME}/.config/opencode"
CE_DATA="${HOME}/.local/share/ce-opencode"

if [ ! -d "$CE_DIR" ]; then
    echo "compound-engineering vendor dir not found" >&2
    exit 1
fi

if ! command -v bun >/dev/null 2>&1; then
    echo "bun not found - skipping CE regeneration" >&2
    exit 0
fi

echo "Regenerating compound-engineering agents..."
CE_DATA_TMP="${CE_DATA}.tmp.$$"
rm -rf "$CE_DATA_TMP"
if ! ( cd "$CE_DIR" && ( [ -d node_modules ] || bun install --silent ) && bun run src/index.ts install compound-engineering --to opencode --output "$CE_DATA_TMP" 2>/dev/null ); then
    rm -rf "$CE_DATA_TMP"
    echo "warning: CE converter failed; skipping CE sync to avoid breaking pipeline" >&2
    exit 0
fi
rm -rf "$CE_DATA"
mv "$CE_DATA_TMP" "$CE_DATA"

# Clean stale CE-managed paths before relinking
rm -rf "${OPENCODE_DIR}/command/compound-engineering"
if [ -d "${OPENCODE_DIR}/command" ]; then
    keep_command_dir="false"
    for entry in "${OPENCODE_DIR}/command"/*; do
        [ -e "$entry" ] || continue
        if [ "$(basename "$entry")" != "compound-engineering" ]; then
            keep_command_dir="true"
            break
        fi
    done
    if [ "$keep_command_dir" = "false" ]; then
        rm -rf "${OPENCODE_DIR}/command"
    fi
fi
rm -rf "${OPENCODE_DIR}/commands/compound-engineering"
rm -rf "${OPENCODE_DIR}/skills/compound-engineering"
rm -rf "${OPENCODE_DIR}/skills/ce"
rm -rf "${OPENCODE_DIR}/commands/ce"
rm -rf "${HOME}/.dotfiles/vendor/compound-engineering-opencode"

mkdir -p "${OPENCODE_DIR}/commands"
mkdir -p "${OPENCODE_DIR}/commands/ce"
mkdir -p "${OPENCODE_DIR}/skills/ce"
mkdir -p "${OPENCODE_DIR}/agents"

# Enabled commands come from converter output and are linked at commands root.
if [ -d "${CE_DATA}/.opencode/commands" ]; then
    for f in "${CE_DATA}/.opencode/commands"/*.md; do
        [ -f "$f" ] || continue
        ensure_link "$f" "${OPENCODE_DIR}/commands/$(basename "$f")"
    done
fi

# Disabled native commands are still exposed under commands/ce.
if [ -d "${CE_PLUGIN}/commands" ]; then
    for f in "${CE_PLUGIN}/commands"/*.md; do
        [ -f "$f" ] || continue
        if grep -q 'disable-model-invocation:[[:space:]]*true' "$f" 2>/dev/null; then
            ensure_link "$f" "${OPENCODE_DIR}/commands/ce/$(basename "$f")"
        fi
    done
fi

# Skills with disable-model-invocation are linked as commands under commands/ce.
# Enabled skills are linked under skills/ce.
if [ -d "${CE_PLUGIN}/skills" ]; then
    for skill_dir in "${CE_PLUGIN}/skills"/*/; do
        [ -d "$skill_dir" ] || continue
        skill_md="${skill_dir}SKILL.md"
        [ -f "$skill_md" ] || continue
        skill_name="$(basename "$skill_dir")"
        if grep -q 'disable-model-invocation:[[:space:]]*true' "$skill_md" 2>/dev/null; then
            ensure_link "$skill_dir" "${OPENCODE_DIR}/commands/ce/${skill_name}"
        else
            ensure_link "$skill_dir" "${OPENCODE_DIR}/skills/ce/${skill_name}"
        fi
    done
fi

# Converted agents are linked to agents root.
if [ -d "${CE_DATA}/.opencode/agents" ]; then
    for f in "${CE_DATA}/.opencode/agents"/*.md; do
        [ -f "$f" ] || continue
        ensure_link "$f" "${OPENCODE_DIR}/agents/$(basename "$f")"
    done
fi

# Merge MCP config only when converter output has .mcp entries and jq is available.
if [ -f "${CE_DATA}/opencode.json" ] && command -v jq >/dev/null 2>&1; then
    if jq -e '.mcp and (.mcp | type == "object") and ((.mcp | length) > 0)' "${CE_DATA}/opencode.json" >/dev/null 2>&1; then
        mkdir -p "${OPENCODE_DIR}"
        if [ ! -f "${OPENCODE_DIR}/opencode.json" ]; then
            printf '{}\n' > "${OPENCODE_DIR}/opencode.json"
        fi
        ce_mcp_json="$(jq -c '.mcp' "${CE_DATA}/opencode.json")"
        check_expr=".mcp? and ((.mcp + ${ce_mcp_json}) == .mcp)"
        transform_expr=".mcp = ((.mcp // {}) + ${ce_mcp_json})"
        ensure_json \
            "${OPENCODE_DIR}/opencode.json" \
            "$check_expr" \
            "$transform_expr" \
            "Merging compound-engineering MCP config..."
    fi
fi
