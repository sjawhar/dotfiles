#!/bin/bash
# Markdown preview server over Tailscale
# Renders markdown to styled HTML with live reload.
# URL is copied to clipboard via OSC 52.

set -euo pipefail

case "${1:-}" in
    --help|-h|"")
        echo "Usage: mdview <file.md>" >&2
        exit 1
        ;;
esac

file="$(realpath "$1")"
if [ ! -f "$file" ]; then
    echo "File not found: $file" >&2
    exit 1
fi

exec uv run "${DOTFILES_DIR:-${HOME}/.dotfiles}/scripts/mdview-server.py" "$file"
