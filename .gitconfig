[pull]
        rebase = true
[alias]
    fc = ! "git fetch --prune --tags --prune-tags"
    gone = ! "git fc && git branch --format '%(refname:short) %(upstream:track)' | awk '$2 == \"[gone]\" {print $1}' | xargs git branch -D 2>/dev/null || true"
[fetch]
        prune = true
[init]
        defaultBranch = main
[push]
        autoSetupRemote = true

[credential "https://github.com"]
	helper = 
	helper = !gh auth git-credential

[credential "https://gist.github.com"]
	helper = 
	helper = !gh auth git-credential
[user]
	email = sami@thecybermonk.com
	name = Sami Jawhar
[filter "lfs"]
	smudge = git-lfs smudge --skip -- %f
	process = git-lfs filter-process --skip
	required = true
	clean = git-lfs clean -- %f
